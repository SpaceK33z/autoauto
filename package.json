{
  "name": "autoauto",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build --compile src/index.tsx --outfile dist/autoauto",
    "lint": "oxlint",
    "typecheck": "bun tsc --noEmit"
  },
  "bin": {
    "autoauto": "./src/index.tsx"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@opentui/core": "latest",
    "@opentui/react": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "oxlint": "^1.58.0",
    "typescript": "^5.7.0"
  }
}
