{
  "name": "@spacek33z/autoauto",
  "version": "1.5.0",
  "description": "TUI tool for autoresearch — autonomous experiment loops on any codebase",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpaceK33z/autoauto.git"
  },
  "author": "Kees Kluskens",
  "homepage": "https://github.com/SpaceK33z/autoauto",
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "autoresearch",
    "tui",
    "ai",
    "automation",
    "experiments",
    "claude",
    "codex"
  ],
  "files": [
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "DEV=1 bun run src/index.tsx",
    "build": "bun build --compile src/index.tsx --outfile dist/autoauto",
    "lint": "oxlint",
    "typecheck": "bun tsc --noEmit",
    "test": "bun test src",
    "test:all": "bun test src"
  },
  "bin": {
    "autoauto": "./src/index.tsx"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@openai/codex-sdk": "^0.118.0",
    "@opencode-ai/sdk": "^1.3.17",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "oxlint": "^1.58.0",
    "typescript": "^5.7.0"
  }
}
